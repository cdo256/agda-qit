module QIT.Topology.Base where

open import QIT.Prelude
open import QIT.Prop
open import QIT.Relation.Subset
open import QIT.Topology.Subset

private
  variable
    тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ : Level

record Space (тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ : Level) : Set (lsuc (тДУЁЭУд тКФ тДУЁЭУЯ тКФ тДУЁЭУЮ)) where
  field
    ЁЭУд        : Set тДУЁЭУд
    ЁЭУЮ        : ЁЭУЯ тДУЁЭУЯ ЁЭУд тЖТ Prop тДУЁЭУЮ
    тИЕтИИЁЭУЮ      : ЁЭУЮ тИЕ
    ЁЭУдтИИЁЭУЮ      : ЁЭУЮ ЁЭУд╠З
    тЛГтИИЁЭУЮ      : (I : Set) (X : I тЖТ ЁЭУЯ тДУЁЭУЯ ЁЭУд)
             тЖТ (тИА i тЖТ ЁЭУЮ (X i))
             тЖТ ЁЭУЮ (тЛГ I X)
    тИйтИИЁЭУЮ      : (X Y : ЁЭУЯ тДУЁЭУЯ ЁЭУд)
             тЖТ ЁЭУЮ X тЖТ ЁЭУЮ Y
             тЖТ ЁЭУЮ (X тИй Y)

тЯи_тЯй : Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ тЖТ Set тДУЁЭУд
тЯи A тЯй = A .Space.ЁЭУд

data ЁЭУЮ[_] {ЁЭУд : Set тДУЁЭУд}
          (ЁЭУЮ : ЁЭУЯ тДУЁЭУЯ ЁЭУд тЖТ Prop тДУЁЭУЮ)
    : ЁЭУЯ тДУЁЭУЯ ЁЭУд
    тЖТ Prop (тДУЁЭУд тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ) where
  ЁЭУЮтИИ[ЁЭУЮ]    : тИА X тЖТ ЁЭУЮ X тЖТ ЁЭУЮ[ ЁЭУЮ ] X
  тИЕтИИ[ЁЭУЮ]    : ЁЭУЮ[ ЁЭУЮ ] тИЕ
  ЁЭУдтИИ[ЁЭУЮ]    : ЁЭУЮ[ ЁЭУЮ ] ЁЭУд╠З
  тЛГтИИ[ЁЭУЮ]    : (I : Set) (X : I тЖТ ЁЭУЯ тДУЁЭУЯ ЁЭУд)
            тЖТ (тИА i тЖТ ЁЭУЮ[ ЁЭУЮ ] (X i))
            тЖТ ЁЭУЮ[ ЁЭУЮ ] (тЛГ I X)
  тИйтИИ[ЁЭУЮ]    : (X Y : ЁЭУЯ тДУЁЭУЯ ЁЭУд)
            тЖТ ЁЭУЮ[ ЁЭУЮ ] X тЖТ ЁЭУЮ[ ЁЭУЮ ] Y
            тЖТ ЁЭУЮ[ ЁЭУЮ ] (X тИй Y)

FreeSpace
  : тИА тДУЁЭУЮ тЖТ (ЁЭУд : Set тДУЁЭУд)
  тЖТ (ЁЭУЮ : ЁЭУЯ тДУЁЭУЯ ЁЭУд тЖТ Prop тДУЁЭУЮ)
  тЖТ Space тДУЁЭУд тДУЁЭУЯ (тДУЁЭУд тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ)
FreeSpace тДУЁЭУЮ ЁЭУд ЁЭУЮ = record
  { ЁЭУд        = ЁЭУд
  ; ЁЭУЮ        = ЁЭУЮ[ ЁЭУЮ ]
  ; тИЕтИИЁЭУЮ      = тИЕтИИ[ЁЭУЮ]
  ; ЁЭУдтИИЁЭУЮ      = ЁЭУдтИИ[ЁЭУЮ]
  ; тЛГтИИЁЭУЮ      = тЛГтИИ[ЁЭУЮ]
  ; тИйтИИЁЭУЮ      = тИйтИИ[ЁЭУЮ]
  }

record _тЗТ_
    {тДУЁЭУЯ тДУЁЭУдтВБ тДУЁЭУЮтВБ тДУЁЭУдтВВ тДУЁЭУЮтВВ}
    (A : Space тДУЁЭУдтВБ тДУЁЭУЯ тДУЁЭУЮтВБ)
    (B : Space тДУЁЭУдтВВ тДУЁЭУЯ тДУЁЭУЮтВВ)
    : Set (lsuc тДУЁЭУЯ тКФ тДУЁЭУдтВБ тКФ тДУЁЭУЮтВБ тКФ тДУЁЭУдтВВ тКФ тДУЁЭУЮтВВ) where
  constructor _,_
  module A = Space A
  module B = Space B
  field
    f  : A.ЁЭУд тЖТ B.ЁЭУд
    fЁЭУЮ : тИА Y тЖТ B.ЁЭУЮ Y тЖТ A.ЁЭУЮ (╬╗ x тЖТ Y (f x))

Restriction
  : тИА {тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ}
  тЖТ (A : Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ)
  тЖТ (X : ЁЭУЯ тДУЁЭУЯ (A .Space.ЁЭУд))
  тЖТ Space (тДУЁЭУд тКФ тДУЁЭУЯ) тДУЁЭУЯ (тДУЁЭУд тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ)
Restriction {тДУЁЭУд} {тДУЁЭУЯ} {тДУЁЭУЮ} A X = FreeSpace _ ЁЭУдRestr ЁЭУЮRestr
  module _ where
  open Space A

  ЁЭУдRestr : Set (тДУЁЭУд тКФ тДУЁЭУЯ)
  ЁЭУдRestr = ╬гP ЁЭУд X

  data ЁЭУЮRestr : ЁЭУЯ тДУЁЭУЯ ЁЭУдRestr тЖТ Prop (тДУЁЭУд тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ) where
    restrict : (Y : ЁЭУЯ тДУЁЭУЯ ЁЭУд) тЖТ ЁЭУЮ Y тЖТ ЁЭУЮRestr (╬╗ (x , _) тЖТ Y x)

Inclusion
  : тИА {тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ}
  тЖТ (A : Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ)
  тЖТ (X : ЁЭУЯ тДУЁЭУЯ (A .Space.ЁЭУд))
  тЖТ Restriction A X тЗТ A
Inclusion {тДУЁЭУЯ = тДУЁЭУЯ} A X = fst , fЁЭУЮ
  where
  module A = Space A
  module B = Space (Restriction A X)

  fЁЭУЮ : (Y : ЁЭУЯ тДУЁЭУЯ A.ЁЭУд) тЖТ A.ЁЭУЮ Y тЖТ B.ЁЭУЮ (╬╗ (x , _) тЖТ Y x)
  fЁЭУЮ Y AЁЭУЮY = ЁЭУЮтИИ[ЁЭУЮ] (╬╗ (x , _) тЖТ Y x) (restrict Y AЁЭУЮY)

Space┬╖ : тИА тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ тЖТ Set (lsuc (тДУЁЭУд тКФ тДУЁЭУЯ тКФ тДУЁЭУЮ))
Space┬╖ тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ = ╬г (Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ) тЯи_тЯй

-- We cannot lift on the subset level тДУЁЭУЯ because it appears negatively in the definition.
LiftSpace : тИА тДУЁЭУд' тДУЁЭУЮ' {тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ} тЖТ Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ тЖТ Space (тДУЁЭУд тКФ тДУЁЭУд') тДУЁЭУЯ (тДУЁЭУЮ тКФ тДУЁЭУЮ')
LiftSpace тДУЁЭУд' тДУЁЭУЮ' X = record
  { ЁЭУд = Lift тДУЁЭУд' ЁЭУд
  ; ЁЭУЮ = ╬╗ A тЖТ LiftP тДУЁЭУЮ' (ЁЭУЮ (╬╗ x тЖТ A (lift x)))
  ; тИЕтИИЁЭУЮ = liftp тИЕтИИЁЭУЮ
  ; ЁЭУдтИИЁЭУЮ = liftp ЁЭУдтИИЁЭУЮ
  ; тЛГтИИЁЭУЮ = ╬╗ I A z тЖТ liftp (тЛГтИИЁЭУЮ I (╬╗ i x тЖТ A i (lift x)) (╬╗ i тЖТ z i .lowerp))
  ; тИйтИИЁЭУЮ = ╬╗ A B z zтВБ тЖТ liftp (тИйтИИЁЭУЮ (╬╗ x тЖТ A (lift x)) (╬╗ x тЖТ B (lift x)) (z .lowerp) (zтВБ .lowerp))
  }
  where open Space X
