module QIT.Topology.Constructions where

open import QIT.Prelude
open import QIT.Prop
open import Data.Bool using (Bool; true; false; if_then_else_)
open import Data.List using (List; []; _тИ╖_)
open import QIT.Relation.Subset
open import QIT.Topology.Subset
open import QIT.Topology.Base
open import QIT.Relation.SetQuotient

тиЖ : тИА {тДУJ тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ}
   тЖТ (J : Set тДУJ)
   тЖТ (J тЖТ Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ)
   тЖТ Space (тДУJ тКФ тДУЁЭУд) тДУЁЭУЯ (тДУJ тКФ тДУЁЭУд тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ)
тиЖ J Aс┤╢ =
  FreeSpace _ тиЖA ЁЭУЮтиЖ
  where
  open Space
  тиЖA : Set _
  тиЖA = ╬г J ╬╗ j тЖТ тЯи Aс┤╢ j тЯй
  ЁЭУЮтиЖ : ЁЭУЯ _ тиЖA тЖТ Prop _
  ЁЭУЮтиЖ X = тИА j тЖТ ЁЭУЮ (Aс┤╢ j) (╬╗ x тЖТ X (j , x))

тиЕ : тИА {тДУJ тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ}
   тЖТ (J : Set тДУJ)
   тЖТ (J тЖТ Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ)
   тЖТ Space (тДУJ тКФ тДУЁЭУд) (тДУJ тКФ тДУЁЭУЯ) (lsuc тДУJ тКФ тДУЁЭУд тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ)
тиЕ {тДУJ} {тДУЁЭУд} {тДУЁЭУЯ} {тДУЁЭУЮ} J Aс┤╢ =
  FreeSpace (тДУJ тКФ тДУЁЭУд тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ) тиЕA ЁЭУЮтиЕ
  where
  open Space
  
  тиЕA : Set (тДУJ тКФ тДУЁЭУд)
  тиЕA = тИА j тЖТ тЯи Aс┤╢ j тЯй
  
  data ЁЭУЮтиЕ : ЁЭУЯ (тДУJ тКФ тДУЁЭУЯ) тиЕA
           тЖТ Prop (тДУJ тКФ тДУЁЭУд тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ)
    where
    introтиЕ : (Xс┤╢ : тИА j тЖТ ЁЭУЯ тДУЁЭУЯ тЯи Aс┤╢ j тЯй)
            тЖТ (ЁЭУЮX : тИА j тЖТ ЁЭУЮ (Aс┤╢ j) (Xс┤╢ j))
            тЖТ ЁЭУЮтиЕ (тиЕ╦в J ╬╗ j x тЖТ Xс┤╢ j x)

_тКФс╡А_
   : тИА {тДУЁЭУд тДУЁЭУе тДУЁЭУЯ тДУЁЭУЮ тДУЁЭУЮ'}
   тЖТ (X : Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ)
   тЖТ (Y : Space тДУЁЭУе тДУЁЭУЯ тДУЁЭУЮ')
   тЖТ Space (тДУЁЭУд тКФ тДУЁЭУе) тДУЁЭУЯ (тДУЁЭУд тКФ тДУЁЭУе тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ тКФ тДУЁЭУЮ')
_тКФс╡А_ {тДУЁЭУд} {тДУЁЭУе} {тДУЁЭУЯ} {тДУЁЭУЮ} {тДУЁЭУЮ'} X Y =
  тиЖ Bool (if_then LiftSpace тДУЁЭУе тДУЁЭУЮ' X else LiftSpace тДУЁЭУд тДУЁЭУЮ Y)

_тКУс╡А_
   : тИА {тДУЁЭУд тДУЁЭУе тДУЁЭУЯ тДУЁЭУЮ тДУЁЭУЮ'}
   тЖТ (X : Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ)
   тЖТ (Y : Space тДУЁЭУе тДУЁЭУЯ тДУЁЭУЮ')
   тЖТ Space (тДУЁЭУд тКФ тДУЁЭУе) тДУЁЭУЯ (тДУЁЭУд тКФ тДУЁЭУе тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ тКФ тДУЁЭУЮ')
_тКУс╡А_ {тДУЁЭУд} {тДУЁЭУе} {тДУЁЭУЯ} {тДУЁЭУЮ} {тДУЁЭУЮ'} X Y =
  тиЕ Bool (if_then LiftSpace тДУЁЭУе тДУЁЭУЮ' X else LiftSpace тДУЁЭУд тДУЁЭУЮ Y)

_/с╡А_
   : тИА {тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ}
   тЖТ (X : Space тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ)
   тЖТ (A : ЁЭУЯ тДУЁЭУЯ (X .Space.ЁЭУд))
   тЖТ Space (тДУЁЭУд тКФ тДУЁЭУЯ) тДУЁЭУЯ (тДУЁЭУд тКФ тДУЁЭУЯ тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ)
_/с╡А_ {тДУЁЭУд} {тДУЁЭУЯ} {тДУЁЭУЮ} X A =
  FreeSpace тДУЁЭУЮ ЁЭУд' ЁЭУЮ'
  where
  module X = Space X
  R : X.ЁЭУд тЖТ X.ЁЭУд тЖТ Prop тДУЁЭУЯ
  R x y = x тИИ A тИз y тИИ A
  ЁЭУд' : Set (тДУЁЭУд тКФ тДУЁЭУЯ)
  ЁЭУд' = X.ЁЭУд / R 
  ЁЭУЮ' : ЁЭУЯ тДУЁЭУЯ ЁЭУд' тЖТ Prop _ 
  ЁЭУЮ' A = X.ЁЭУЮ (╬╗ x тЖТ [ x ] тИИ A)

_тИис╡А_
   : тИА {тДУЁЭУд тДУЁЭУе тДУЁЭУЯ тДУЁЭУЮ тДУЁЭУЮ'}
   тЖТ (X : Space┬╖ тДУЁЭУд тДУЁЭУЯ тДУЁЭУЮ)
   тЖТ (Y : Space┬╖ тДУЁЭУе тДУЁЭУЯ тДУЁЭУЮ')
   тЖТ Space┬╖ {!тДУЁЭУд тКФ тДУЁЭУе!} {!тДУЁЭУЯ!} {!тДУЁЭУд тКФ тДУЁЭУе тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ тКФ тДУЁЭУЮ'!}
_тИис╡А_ {тДУЁЭУд} {тДУЁЭУе} {тДУЁЭУЯ} {тДУЁЭУЮ} {тДУЁЭУЮ'} (X , x) (Y , y) =
  {!!} , {!!}   
  where
  Z = (X тКФс╡А Y)
  module Z = Space Z
  Q : ЁЭУЯ _ Z.ЁЭУд
  Q z = z тЙб (true , lift x) тИи z тЙб (false , lift y) 
  Z/Q : Space _ _ _
  Z/Q = Z /с╡А {!Q!}
--   Q : ЁЭУЯ _ (XтКФ тКФс╡А Y)
--   Q = ?
--   Z : Space (тДУЁЭУд тКФ тДУЁЭУе тКФ тДУЁЭУЯ) тДУЁЭУЯ
--        (тДУЁЭУд тКФ тДУЁЭУе тКФ тДУЁЭУЯ тКФ lsuc тДУЁЭУЯ тКФ (тДУЁЭУд тКФ тДУЁЭУе тКФ lsuc тДУЁЭУЯ тКФ тДУЁЭУЮ тКФ тДУЁЭУЮ'))
--   Z = (X тКФс╡А Y) /с╡А Q


