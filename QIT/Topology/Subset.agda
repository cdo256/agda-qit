open import QIT.Prelude
open import QIT.Prop
open import Data.List
open import QIT.Relation.Subset

open Subset

infix 40 _Г—Лў_ _+Лў_

_Г—Лў_ : вҲҖ {в„“рқ“Ө в„“рқ“Ҙ в„“рқ“ҹ} {рқ“Ө : Set в„“рқ“Ө} {рқ“Ҙ : Set в„“рқ“Ҙ}
     вҶ’ рқ“ҹ в„“рқ“ҹ рқ“Ө вҶ’ рқ“ҹ в„“рқ“ҹ рқ“Ҙ вҶ’ рқ“ҹ _ (рқ“Ө Г— рқ“Ҙ)
(X Г—Лў Y) (x , y) = x вҲҲ X вҲ§ y вҲҲ Y

вЁ…Лў : вҲҖ {в„“J в„“рқ“Ө в„“рқ“ҹ} (J : Set в„“J) {рқ“Ө : J вҶ’ Set в„“рқ“Ө}
     вҶ’  (Aбҙ¶ : вҲҖ j вҶ’ рқ“ҹ в„“рқ“ҹ (рқ“Ө j)) вҶ’ рқ“ҹ (в„“J вҠ” в„“рқ“ҹ) (вҲҖ j вҶ’ рқ“Ө j)
вЁ…Лў J Aбҙ¶ X = вҲҖ j вҶ’ Aбҙ¶ j (X j)


_+Лў_ : вҲҖ {в„“рқ“Ө в„“рқ“Ҙ в„“рқ“ҹ} {рқ“Ө : Set в„“рқ“Ө} {рқ“Ҙ : Set в„“рқ“Ҙ}
     вҶ’ рқ“ҹ в„“рқ“ҹ рқ“Ө вҶ’ рқ“ҹ в„“рқ“ҹ рқ“Ҙ вҶ’ рқ“ҹ _ (рқ“Ө вҠҺ рқ“Ҙ)
(X +Лў Y) (injвӮҒ x) = x вҲҲ X
(X +Лў Y) (injвӮӮ y) = y вҲҲ Y


вЁҶЛў : вҲҖ {в„“J в„“рқ“Ө в„“рқ“ҹ} (J : Set в„“J) {рқ“Ө : J вҶ’ Set в„“рқ“Ө}
     вҶ’  (Aбҙ¶ : вҲҖ j вҶ’ рқ“ҹ в„“рқ“ҹ (рқ“Ө j)) вҶ’ рқ“ҹ _ (ОЈ J рқ“Ө)
вЁҶЛў J Aбҙ¶ (j , x) = x вҲҲ Aбҙ¶ j
